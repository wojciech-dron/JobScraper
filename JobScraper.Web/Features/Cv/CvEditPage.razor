@page "/Cv/edit"
@page "/Cv/edit/{Id:int}"
@using BlazorBootstrap
@using Blazored.FluentValidation
@using ErrorOr
@using JobScraper.Web.Blazor.Components
@using JobScraper.Web.Blazor.Extensions
@using JobScraper.Web.Common.Entities
@using JobScraper.Web.Features.Cv.Components
@using JobScraper.Web.Features.Cv.Helpers
@using JobScraper.Web.Features.Cv.PdfGeneration
@using JobScraper.Web.Modules.Persistence
@using Microsoft.EntityFrameworkCore
@using Wolverine

<NavigationLock ConfirmExternalNavigation="@PreventNavigation"
                OnBeforeInternalNavigation="OnBeforeInternalNavigation"/>

<Toasts class="p-3" Messages="toasts" Placement="ToastsPlacement.TopRight"/>

<EditForm Model="@_cv" OnValidSubmit="SaveAsync">
    <FluentValidationValidator @ref="validator"/>

    <div class="row vh-100 pt-2">
        <div class="col-md-9">
            <h2>Edit CV</h2>

            <div class="row">
                <div class="col-md-3">
                    <div class="input-group input-group-sm mb-3">
                        <span class="input-group-text px-1 py-0 small text-muted" title="Bullet Width">Name</span>
                        <TextInput @bind-Value="_cv.Name" class="form-control"/>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text px-1 py-0 small text-muted"
                              title="Value indicating that CV is selected for template for creating dedicated CVs for offers">
                            Is Template
                        </span>
                        <InputSelect @bind-Value="_cv.IsTemplate" class="form-control">
                            <option value="false">No</option>
                            <option value="true">Yes</option>
                        </InputSelect>
                    </div>
                </div>
                <div class="col-md-3">
                    <InputFile class="@(HasImage ? "hide-file-name" : null)"
                               title="@(HasImage ? _cv.Image!.FileName : null)"
                               OnChange="UploadImage"
                               accept="image/*"
                               disabled="@isWorking"/>
                    @{
                        var image = _cv.Image;
                    }
                    @if (image is not null)
                    {
                        <div class="mt-2 d-flex flex-column gap-1">
                            <div class="small">
                                <a href="@GetImageUrl(image.Id)" target="_blank">@image.FileName</a>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <button class="btn btn-info btn-sm"
                    @onclick="CompareToOrigin"
                    disabled="@DisableCompareToOrigin">Compare with origin</button>

            <button class="btn btn-info btn-sm"
                    @onclick="CompareToSaved"
                    disabled="@DisableCompareToSaved">Compare with saved</button>

            <MarkdownDiffEditor @ref="_diffEditor"
                                CssClass="h-75 mt-3"
                                InitOriginalContent="@OriginalContent"
                                InitModifiedContent="@ModifiedContent"/>

            <div class="col-md-3 input-group input-group-sm mt-3">
                <span class="input-group-text px-1 py-0 small text-muted"
                      title="Disclaimer content positioned on the footer">Disclaimer</span>
                <TextAreaInput @bind-Value="_cv.Disclaimer" class="form-control"/>
            </div>

            <ValidationSummary/>
        </div>

        <div class="col-md-3">
            <h5>Layout settings</h5>
            <LayoutConfigComponent Config="_cv.LayoutConfig"/>
            <button class="btn btn-primary mt-2"
                    disabled="@isWorking"
                    @onclick="GenerateCvPdf">
                Generate CV
            </button>
            <button class="btn btn-success mt-2"
                    disabled="@isWorking"
                    @onclick="SaveAsync">
                Save changes
            </button>




        </div>
    </div>
</EditForm>

@inject IJSRuntime JS
@inject JobsDbContext DbContext
@inject IMessageBus MessageBus
@inject NavigationManager NavigationManager

<style>
    input[type="file"].hide-file-name {
    }

    input[type="file"].hide-file-name::file-selector-button {
        color: inherit;
    }
</style>

@code {
    private readonly List<ToastMessage> toasts = [];
    private FluentValidationValidator validator = null!;
    private IJSObjectReference? _downloadModule;
    private readonly CancellationTokenSource _cts = new();
    private MarkdownDiffEditor? _diffEditor;
    private bool isWorking;

    private CompareMode _compareMode = CompareMode.WithSaved;
    private CvEntity _cv = null!;
    private ElementReference? _imageElement;
    private string OriginalContent = "";
    private string ModifiedContent = "";
    private bool HasImage => _cv?.Image is not null;

    [Parameter]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Id == 0)
        {
            _cv = new()
            {
                Name = "Test",
            };
        }
        else
        {
            _cv = await DbContext.Cvs
                .Include(c => c.OriginCv)
                .Include(c => c.Image)
                .FirstOrDefaultAsync(c => c.Id == Id, _cts.Token)
            ?? throw new InvalidOperationException($"CV with ID {Id} not found");
        }

        var image = _cv.Image;
        if (image is not null)
        {

        }

        OriginalContent = _cv.MarkdownContent;
        ModifiedContent = _cv.MarkdownContent;
    }

    private const long MaxImageBytes = 5 * 1024 * 1024;

    private async Task UploadImage(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file.Size == 0)
        {
            toasts.PushMessage("Cannot upload empty file", ToastType.Warning);
            return;
        }

        if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            toasts.PushMessage("Only image files are allowed", ToastType.Warning);
            return;
        }

        if (file.Size > MaxImageBytes)
        {
            toasts.PushMessage("Image is too large (max 5 MB)", ToastType.Warning);
            return;
        }

        isWorking = true;

        try
        {
            await using var inputStream = file.OpenReadStream(MaxImageBytes, _cts.Token);
            await using var memoryStream = new MemoryStream();
            await inputStream.CopyToAsync(memoryStream, _cts.Token);

            var image = new ImageEntity
            {
                FileName = file.Name,
                ContentType = file.ContentType,
                Size = file.Size,
                Data = memoryStream.ToArray(),
            };

            DbContext.Add(image);
            await DbContext.SaveChangesAsync(_cts.Token);

            _cv.Image = image;
            toasts.PushMessage("Image uploaded successfully");
        }
        catch (Exception e)
        {
            toasts.PushMessage("Failed to upload image: " + e.Message, ToastType.Danger);
        }
        finally
        {
            isWorking = false;
        }
    }

    private string GetImageUrl(long imageId) => $"/api/cv-images/{imageId}";

    public async Task SaveAsync()
    {
        if (_diffEditor is null)
            return;

        _cv.MarkdownContent = await _diffEditor.GetModifiedValueAsync();

        if (!await validator.ValidateAsync())
            return;

        if (DbContext.Entry(_cv).State == EntityState.Detached)
            DbContext.Add(_cv);

        await DbContext.SaveChangesAsync(_cts.Token);

        if (_compareMode == CompareMode.WithSaved)
            OriginalContent = _cv.MarkdownContent;

        toasts.PushMessage("CV saved successfully");
        NavigationManager.NavigateTo($"cv/edit/{_cv.Id}");
    }

    private async Task GenerateCvPdf()
    {
        if (_diffEditor is null)
            return;

        var mdContent = await _diffEditor.GetModifiedValueAsync();
        if (string.IsNullOrWhiteSpace(mdContent))
            return;

        isWorking = true;

        var cvContent = new CvContent(mdContent, _cv.Image?.Data);
        var request = new GenerateCvPdfFromMarkdown.Request(cvContent, _cv.LayoutConfig);

        ErrorOr<byte[]> result;
        try
        {
            result = await MessageBus.InvokeAsync<ErrorOr<byte[]>>(request);
        }
        catch (Exception e)
        {
            var errorMessage = e.Message.ToFriendlyErrorMessage();
            toasts.PushMessage("Failed to generate CV PDF: " + errorMessage, ToastType.Danger);
            isWorking = false;
            return;
        }

        isWorking = false;

        if (result.IsError)
        {
            toasts.PushMessage("Failed to generate CV PDF", ToastType.Danger);
            return;
        }

        var fileName = $"{_cv.Name}.pdf";
        var pdfBytes = result.Value;
        using var stream = new MemoryStream(pdfBytes);
        using var streamRef = new DotNetStreamReference(stream);

        _downloadModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/downloadFile.js");
        await _downloadModule.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);

        toasts.PushMessage("CV PDF generated successfully");
    }

    private enum CompareMode
    {
        None,
        WithSaved,
        WithOrigin,
    }

    public bool DisableCompareToOrigin =>
        _compareMode is CompareMode.WithOrigin || string.IsNullOrWhiteSpace(_cv?.OriginCv?.MarkdownContent);
    private void CompareToOrigin()
    {
        ArgumentException.ThrowIfNullOrWhiteSpace(_cv?.OriginCv?.MarkdownContent);
        _compareMode = CompareMode.WithOrigin;
        OriginalContent = _cv?.OriginCv?.MarkdownContent!;
    }

    public bool DisableCompareToSaved => _compareMode is CompareMode.WithSaved;
    private void CompareToSaved()
    {
        ArgumentException.ThrowIfNullOrWhiteSpace(_cv?.MarkdownContent);
        _compareMode = CompareMode.WithSaved;
        OriginalContent = _cv?.MarkdownContent!;
    }

    private bool PreventNavigation => isWorking || DbContext.Entry(_cv).State == EntityState.Modified;

    private async Task OnBeforeInternalNavigation(LocationChangingContext ctx)
    {
        if (!PreventNavigation)
            return;

        var confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to leave this page?");
        if (!confirm)
            ctx.PreventNavigation();
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
