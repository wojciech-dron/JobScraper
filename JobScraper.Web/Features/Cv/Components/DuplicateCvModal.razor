@using BlazorBootstrap
@using JobScraper.Web.Blazor.Components.ButtonSelect
@using JobScraper.Web.Blazor.Extensions
@using JobScraper.Web.Common.Entities
@using JobScraper.Web.Features.Cv.Logic
@using JobScraper.Web.Modules.Persistence
@using Mediator
@using Microsoft.EntityFrameworkCore
<Toasts class="p-3" Messages="toasts" Placement="ToastsPlacement.TopRight"/>

<Modal @ref="_modal" Title="Create duplicate CV" Size="ModalSize.Large">
    <BodyTemplate>
        <div class="form-group">
            @if (ShowCvSelector)
            {
                <ButtonSelect TItem="CvEntity"
                              Items="_cvs"
                              SelectedItem="_selectedCv"
                              SelectedItemChanged="OnCvSelected"
                              StringSelector="cv => cv.Name"
                              CanFilter="true"
                              Label="Select source CV:"
                              FilterPlaceholder="Search by CV name"
                              EmptyText="No CVs found"
                              Id="cv-search"/>
            }

            <label for="new-cv-name">New Cv Name:</label>
            <InputText id="new-cv-name" @bind-Value="@NewCvName" class="form-control"/>
        </div>
        <button class="btn btn-success mt-2"
                disabled="@isWorking"
                @onclick="SaveAsync">
            Create duplicate
        </button>
    </BodyTemplate>
</Modal>

@inject IMediator Mediator
@inject JobsDbContext DbContext

@code {
    private Modal _modal = default!;
    readonly List<ToastMessage> toasts = [];
    private List<CvEntity> _cvs = [];
    private bool isWorking;
    private CvEntity? _selectedCv;

    [Parameter] public long OriginCvId { get; set; }
    [Parameter] public string NewCvName { get; set; } = string.Empty;
    [Parameter] public bool ShowCvSelector { get; set; }
    [Parameter] public EventCallback<long> OnSuccess { get; set; }
    [Parameter] public string? TargetOfferUrl { get; set; }

    public async Task ShowAsync(
        long originCvId = 0,
        string newCvName = "",
        string? offerUrl = null)
    {
        if (ShowCvSelector)
            await LoadCvCandidatesAsync();

        if (originCvId > 0)
            OriginCvId = originCvId;

        if (!string.IsNullOrWhiteSpace(newCvName))
            NewCvName = newCvName;

        if (!string.IsNullOrWhiteSpace(offerUrl))
            TargetOfferUrl = offerUrl;

        await _modal.ShowAsync();
    }

    private async Task LoadCvCandidatesAsync()
    {
        _cvs = await DbContext.Cvs
            .AsNoTracking()
            .Where(cv => cv.IsTemplate)
            .OrderBy(c => c.Id)
            .ToListAsync();

        if (OriginCvId <= 0 && _cvs.Count > 0)
            OriginCvId = _cvs[0].Id;

        _selectedCv = _cvs.FirstOrDefault(cv => cv.Id == OriginCvId);
    }

    private void OnCvSelected(CvEntity? cv)
    {
        _selectedCv = cv;
        OriginCvId = cv?.Id ?? 0;
    }

    public async Task SaveAsync()
    {
        if (OriginCvId <= 0)
        {
            toasts.PushMessage("Invalid id of CV to duplicate", ToastType.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(NewCvName) || DbContext.Cvs.Any(c => c.Name == NewCvName))
        {
            toasts.PushMessage("Cv name cannot be empty or already exists", ToastType.Warning);
            return;
        }

        isWorking = true;
        StateHasChanged();

        var message = new DuplicateCv.Command(
            OriginCvId: OriginCvId,
            CvName: NewCvName,
            OfferUrl: TargetOfferUrl);

        var response = await Mediator.Send(message);

        if (response.IsError)
        {
            toasts.PushMessage(response.FirstError.Description, ToastType.Warning);
            return;
        }

        toasts.PushMessage("Cv duplicated successfully");
        StateHasChanged();

        await Task.Delay(1000);
        await _modal.HideAsync();
        await OnSuccess.InvokeAsync(response.Value.Id);
    }
}
