@using JobScraper.Web.Common.Models
@implements IAsyncDisposable
<div class="d-flex flex-column h-100">
    @if (ChatHistory.Count > 0)
    {
        <h4>AI chat</h4>
        <div @ref="chatContainerRef" class="flex-grow-1 overflow-auto">
            <ChatHistory Items="ChatHistory"/>
        </div>
    }
    else
    {
        <div class="flex-grow-1 d-flex align-items-center justify-content-center text-muted">
            <span>Start a conversation or use "Prepare CV content with AI"</span>
        </div>
    }

    <form @onsubmit="SendMessage" @onsubmit:preventDefault class="mt-2">
        <div class="input-group input-group-sm">
            <textarea class="form-control"
                      rows="4"
                      placeholder="Ask about CV or request changes..."
                      @bind="userMessage"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      @onkeydown:preventDefault="shouldPreventDefault"
                      disabled="@IsWorking"></textarea>
            <button type="submit" class="btn btn-primary btn-sm"
                    disabled="@(IsWorking || string.IsNullOrWhiteSpace(userMessage))">
                Send
            </button>
        </div>
    </form>
</div>

@code {
    private string userMessage = "";
    private bool shouldPreventDefault;
    private ElementReference chatContainerRef;
    private IJSObjectReference? module;

    [Parameter] public List<ChatItem> ChatHistory { get; set; } = [];
    [Parameter] public bool IsWorking { get; set; }
    [Parameter] public EventCallback<string> OnSendMessage { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (ChatHistory.Count == 0)
            return;

        module ??= await JS.InvokeAsync<IJSObjectReference>("import",
            $"./Features/Cv/Components/{nameof(CvChat)}.razor.js");

        await module.InvokeVoidAsync("scrollToBottom", chatContainerRef);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", ShiftKey: false })
        {
            shouldPreventDefault = true;
            await SendMessage();
        }
        else
        {
            shouldPreventDefault = false;
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userMessage) || IsWorking)
            return;

        var message = userMessage;
        userMessage = "";
        await OnSendMessage.InvokeAsync(message);
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
            await module.DisposeAsync();
    }
}
