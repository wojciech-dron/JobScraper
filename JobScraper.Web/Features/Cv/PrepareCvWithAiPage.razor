@page "/cv/prepare-with-ai/{CvId:long}"
@using BlazorBootstrap
@using Blazored.FluentValidation
@using JobScraper.Web.Features.Cv.Components

<style>
    .cv-container {
        display: flex;
        height: 85vh;
        overflow: hidden;
    }

    #offer-panel > h4 {
        color: #FFC2B2;
    }

    #offer-panel > span {
        white-space: pre-line;
        font-size: 12px;
    }
</style>

<AppPageTitle Title="Prepare CV with AI"></AppPageTitle>

<NavigationLock ConfirmExternalNavigation="@PreventNavigation"
                OnBeforeInternalNavigation="OnBeforeInternalNavigation"/>

<Toasts class="p-3" Messages="_toasts" Placement="ToastsPlacement.TopRight"/>

<h3>Prepare CV with AI</h3>

<EditForm Model="@cvEntity">
    <FluentValidationValidator @ref="validator"/>

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="input-group input-group-sm mb-3">
                <span class="input-group-text px-1 py-0 small text-muted" title="Cv name">Name</span>
                <TextInput @bind-Value="cvEntity.Name" class="form-control"/>
            </div>
        </div>
        <div class="col-md-1">
            @if (cvEntity.OriginCv is not null)
            {
                <a href="/cv/edit/@cvEntity.OriginCv.Id">
                    <button class="btn btn-info btn-sm"
                            disabled="@isWorking">
                        Origin CV
                    </button>
                </a>
            }
        </div>

        <div class="col-md-3">
            <button class="btn btn-info btn-sm"
                    @onclick="CompareToOrigin"
                    disabled="@DisableCompareToOrigin">
                Compare with origin
            </button>

            <button class="btn btn-info btn-sm"
                    @onclick="CompareToSaved"
                    disabled="@DisableCompareToSaved">
                Compare with saved
            </button>
        </div>

        <div class="col-md-4 text-end">
            @if (isWorking)
            {
                <div class="spinner-border" role="status">
                    <span class="sr-only"></span>
                </div>
            }
            <a href="/cv/@cvEntity.Id/pdf" target="_blank">
                <button class="btn btn-primary btn-sm"
                        disabled="@isWorking">
                    Show PDF
                </button>
            </a>
            <button class="btn btn-primary btn-sm"
                    disabled="@isWorking"
                    @onclick="GenerateCvPdf">
                Save PDF
            </button>
            @if (offer is not null)
            {
                <button class="btn btn-primary btn-sm ms-1"
                        disabled="@isWorking"
                        title="Adjusts CV content with AI, with user defined rules in AI Summary"
                        @onclick="PrepareCvContent">
                    Adjust with AI
                </button>
            }
            @if (offer is not null)
            {
                <a class="ms-1" href="/?offerUrl=@Uri.EscapeDataString(offer.OfferUrl)">
                    <button class="btn btn-info btn-sm" disabled="@isWorking">Offer</button>
                </a>
            }
            <a class="ms-1" href="/cv/edit/@cvEntity.Id">
                <button class="btn btn-info btn-sm" disabled="@isWorking">
                    CV page
                </button>
            </a>
            <button class="btn btn-success btn-sm"
                    disabled="@isWorking"
                    @onclick="SaveAsync">
                Save changes
            </button>
            <button class="btn btn-danger btn-sm"
                    disabled="@isWorking"
                    @onclick="DeleteCvAsync">
                Delete
            </button>
        </div>
    </div>

    <div id="resizable-panels" class="cv-container">
        @if (offer is not null)
        {
            <div id="offer-panel" class="overflow-auto" style="flex: 0 0 450px; min-width: 200px;">
                @if (!string.IsNullOrEmpty(offer.AiSummary))
                {
                    <h4>Ai Summary:</h4>
                    <span>
                        @offer.AiSummary
                    </span>
                }

                <h4>Description:</h4>
                <span>
                    @offer.Details.Description
                </span>

            </div>
            <div class="gutter"
                 style="flex: 0 0 5px; cursor: col-resize; background-color: #dee2e6; user-select: none;"></div>
        }
        <div id="editor-panel" style="flex: 1 1 auto; min-width: 400px;">
            <MarkdownDiffEditor
                @ref="diffEditor"
                OriginalContent="@originalContent"
                ModifiedContent="@modifiedContent"
                CssClass="h-100"
                Inline
                OnModifiedContentChanged="OnEditorContentChanged"/>
        </div>
        <div class="gutter"
             style="flex: 0 0 5px; cursor: col-resize; background-color: #dee2e6; user-select: none;"></div>
        <div id="right-panel" class="overflow-auto ps-1" style="flex: 0 0 500px; min-width: 200px;">
            <CvChat ChatHistory="cvEntity.ChatHistory"
                      IsWorking="isWorking"
                      OnSendMessage="SendChatMessage"/>
        </div>
    </div>

</EditForm>

<ConfirmDialog @ref="dialog"/>
