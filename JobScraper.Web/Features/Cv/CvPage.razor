@page "/Cv/{Id:int}"
@using BlazorMonaco.Editor
@using JobScraper.Web.Blazor.Components
@using JobScraper.Web.Features.Cv.Components
@inject IJSRuntime jsRuntime

<MarkdownDiffEditor @ref="_diffEditor" InitOriginalContent="@OriginalContent" InitModifiedContent="@ModifiedContent" />

@code {
    private readonly string OriginalContent = TestData.BaseCv;
    private readonly string ModifiedContent = TestData.ModifiedCv;
    private MarkdownDiffEditor? _diffEditor;

    [Parameter]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
    }

    public async Task<string?> GetModifiedValue() => _diffEditor is not null
        ? await _diffEditor.GetModifiedValueAsync()
        : null;
}
