@page "/cv/prepare-for-offer/{OfferUrl}"
@using BlazorBootstrap
@using JobScraper.Web.Blazor.Components
@using JobScraper.Web.Common.Entities
@using JobScraper.Web.Common.Models
@using JobScraper.Web.Features.Cv.Components
@using JobScraper.Web.Features.Cv.PdfGeneration
@using System.IO
@using ErrorOr
@using JobScraper.Web.Blazor.Extensions
@using JobScraper.Web.Features.AiSummary.Logic
@using JobScraper.Web.Modules.Persistence
@using Microsoft.EntityFrameworkCore
@using Wolverine

<Toasts class="p-3" Messages="toasts" Placement="ToastsPlacement.TopRight"/>

<div id="resizable-panels" class="d-flex vh-100 overflow-hidden">
    <div id="ai-panel" class="overflow-auto" style="flex: 0 0 450px; min-width: 200px;">
        @if (!string.IsNullOrEmpty(_offer.AiSummary))
        {
            <h4 style="color: #FFC2B2">Ai Summary:</h4>
            <span style="white-space: pre-line; font-size: 12px;">
                @_offer.AiSummary
            </span>
        }
    </div>
    <div class="gutter" style="flex: 0 0 5px; cursor: col-resize; background-color: #dee2e6; user-select: none;"></div>
    <div id="editor-panel" style="flex: 1 1 auto; min-width: 400px;">
        <MarkdownDiffEditor
            @ref="_diffEditor"
            InitOriginalContent="@OriginalContent"
            InitModifiedContent="@ModifiedContent"
            CssClass="h-100"
            Inline/>
    </div>
    <div class="gutter" style="flex: 0 0 5px; cursor: col-resize; background-color: #dee2e6; user-select: none;"></div>
    <div id="right-panel" class="overflow-auto ps-1" style="flex: 0 0 500px; min-width: 200px;">
        <button class="btn btn-primary"
                disabled="@isWorking"
                @onclick="GenerateCvPdf">
            Generate CV
        </button>
        <button class="btn btn-primary"
                disabled="@isWorking"
                @onclick="PrepareCvContent">
            Prepare CV content with AI
        </button>
        @if (_cv.Id > 0)
        {
            <a href="/cv/edit/@_cv.Id">
                <button class="btn btn-success">Manage CV</button>
            </a>
        }

        @if (isWorking)
        {
            <div class="spinner-border" role="status">
                <span class="sr-only"></span>
            </div>
        }
        <br/>
        <br/>

        @if (chatHistory.Count > 0)
        {
            <h4>Agents chat history</h4>
            <ChatHistory Items="chatHistory"/>
        }
    </div>
</div>

@implements IAsyncDisposable
@inject IMessageBus MessageBus
@inject IJSRuntime JS
@inject JobsDbContext DbContext

@code {
    private IJSObjectReference? _module;
    private IJSObjectReference? _downloadModule;

    private bool isWorking;
    private UserOffer _offer = null!;
    private CvEntity _cv = null!;
    private MarkdownDiffEditor _diffEditor = null!;
    private List<ChatItem> chatHistory = TestData.Chat;
    readonly List<ToastMessage> toasts = [];

    private readonly byte[] CvImage = TestData.Image;
    private readonly string OriginalContent = TestData.BaseCv;
    private string ModifiedContent = TestData.BaseCv;

    [Parameter] public string? OfferUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _offer = await DbContext.UserOffers
            .Include(x => x.Details)
            .Include(x => x.Cv)
            .FirstAsync(x => x.OfferUrl == OfferUrl);

        ArgumentNullException.ThrowIfNull(_offer.Cv);
        _cv = _offer.Cv;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Features/Cv/PrepareCvForOfferPage.razor.js");
        await _module.InvokeVoidAsync("initPrepareCvResizers");

    }

    private async Task GenerateCvPdf()
    {
        var mdContent = await _diffEditor.GetModifiedValueAsync();
        if (string.IsNullOrWhiteSpace(mdContent))
            return;

        isWorking = true;

        var cvContent = new CvContent(mdContent, CvImage);
        var layoutConfig = new LayoutConfig();
        var request = new GenerateCvPdfFromMarkdown.Request(cvContent, layoutConfig);
        var result = await MessageBus.InvokeAsync<ErrorOr<byte[]>>(request);

        isWorking = false;

        if (result.IsError)
        {
            toasts.PushMessage("Failed to generate CV PDF", ToastType.Danger);
            return;
        }

        var fileName = $"{_offer.Details.CompanyName}_CV.pdf";
        var pdfBytes = result.Value;
        using var stream = new MemoryStream(pdfBytes);
        using var streamRef = new DotNetStreamReference(stream);

        _downloadModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/downloadFile.js");
        await _downloadModule.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);

        toasts.PushMessage("CV PDF generated successfully");
    }

    private async Task PrepareCvContent()
    {
        var cvContent = await _diffEditor.GetModifiedValueAsync();
        if (string.IsNullOrWhiteSpace(cvContent))
            return;

        if (_offer.Details.Description == null)
            return;

        isWorking = true;
        toasts.PushMessage("Preparing CV content. It could take a while");

        var request = new AdjustCvContentToOffer.Request(
            CvContent: cvContent,
            OfferContent: _offer.Details.Description,
            OfferSummary: _offer.AiSummary);

        var result = await MessageBus.InvokeAsync<AdjustCvContentToOffer.Response>(request);

        isWorking = false;
        chatHistory = result.ChatHistory;

        if (!result.Success)
        {
            toasts.PushMessage("Failed to prepare CV content. Check agents chat history.", ToastType.Warning);
            return;
        }

        toasts.PushMessage("CV content prepared successfully");

        if (chatHistory.Count > 0)
            chatHistory.RemoveAt(chatHistory.Count - 1); // remove last item because it is CV content

        ModifiedContent = result.AdjustedCvContent;
        _ =_diffEditor.SetModifiedModel(ModifiedContent);
    }

    public async ValueTask DisposeAsync()
    {
        if (_downloadModule is not null)
        {
            await _downloadModule.DisposeAsync();
        }
    }

}
