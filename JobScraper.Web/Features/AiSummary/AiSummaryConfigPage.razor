@page "/ai-summary/config"
@using BlazorBootstrap
@using Blazored.FluentValidation

<NavigationLock ConfirmExternalNavigation="@PreventNavigation"
                OnBeforeInternalNavigation="OnBeforeInternalNavigation"/>

<Toasts class="p-3" Messages="messages" Placement="ToastsPlacement.TopRight"/>

<h2>AI Summary</h2>

<EditForm Model="form" disabled="@isWorking">
    <FluentValidationValidator @ref="validator"/>

    <h4>Summary configuration</h4>

    <div class="col-md-6 mb-3">
        <label for="providerName" class="form-label bold">AI Provider name</label>
        <div class="row">
            <div class="col-md-8">
                <InputText id="providerName" class="form-control" @bind-Value="form.ProviderName"/>
            </div>
            <div class="col-md-4">
                <button class="btn btn-secondary" @onclick="VerifyProvider" disabled="@isWorking">
                    Verify provider
                </button>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <label for="aiSummaryEnabled" class="form-label bold">Enable summarization for new offers</label>
        <InputSelect id="aiSummaryEnabled" @bind-Value="@form.AiSummaryEnabled" class="form-control">
            <option value="false">No</option>
            <option value="true">Yes</option>
        </InputSelect>
    </div>

    <div class="mb-3">
        <label for="userRequirements" class="form-label bold">User requirements (optional)</label>
        <InputTextArea id="userRequirements" class="form-control" @bind-Value="form.UserRequirements"/>
    </div>

    <div class="mb-3">
        <label for="cvContent" class="form-label bold">Cv content (do not provide any personal information)</label>
        <InputTextArea id="cvContent" class="form-control" @bind-Value="form.CvContent"/>
    </div>

    <div class="row">
        <div class="col-md-4 d-flex flex-column">
            <button class="btn btn-primary mb-3" @onclick="ScheduleSummaryJob" disabled="@isWorking">
                Schedule AI summary job for marked offers
            </button>
        </div>

        <div class="col-md-4 d-flex flex-column">
            <button class="btn btn-success mb-3" @onclick="SaveConfig" disabled="@isWorking">
                Save config
            </button>
        </div>
    </div>
    <ValidationSummary/>

    <h4>Testing</h4>

    <div class="mb-3">
        <label for="offerContent" class="form-label bold">Test offer content</label>
        <InputTextArea id="offerContent" class="form-control" @bind-Value="form.TestOfferContent"/>
    </div>

    <div class="row">
        <div class="col-md-4 d-flex flex-column">
            <button class="btn btn-primary mb-3" @onclick="SummarizeTestOfferContent" disabled="@isWorking">
                Summarize test offer content
            </button>
        </div>
    </div>

    @if (isWorking)
    {
        <div class="mt-3">
            <h4>Status:</h4>
            <div class="spinner-border" role="status">
                <span class="sr-only"></span>
            </div>
            <h5>Do not leave this page. Operation is in progress...</h5>
        </div>
    }

    @if (chatHistory?.Count > 0)
    {
        <h4>Chat history</h4>
        <div class="chat-container">
            <div class="chat-messages p-3 border rounded mb-3">
                @foreach (var chatItem in chatHistory)
                {
                    <div class="message ai-message">
                        <strong>@chatItem.AuthorName</strong>
                        <pre>@chatItem.Content</pre>
                    </div>
                }
            </div>
        </div>
    }
</EditForm>

@code
{
    List<ChatItem> chatHistory = [];
    readonly List<ToastMessage> messages = [];

    private void PushNotification(string message, ToastType toastType = ToastType.Success) =>
        messages.Insert(0, new ToastMessage
        {
            Type = toastType,
            Message = message,
        });

    private bool PreventNavigation => isWorking;

    private async Task OnBeforeInternalNavigation(LocationChangingContext ctx)
    {
        if (!PreventNavigation)
            return;

        var confirm = await js.InvokeAsync<bool>("confirm", "Are you sure you want to leave this page?");
        if (!confirm)
            ctx.PreventNavigation();
    }
}
