@page "/ai-summary/config"
@using BlazorBootstrap
@using Blazored.FluentValidation

<NavigationLock ConfirmExternalNavigation="@PreventNavigation"
                OnBeforeInternalNavigation="OnBeforeInternalNavigation"/>

<Toasts class="p-3" Messages="messages" Placement="ToastsPlacement.TopRight"/>

<h2>AI Summary</h2>

<EditForm Model="_request" disabled="@isWorking">
    <FluentValidationValidator @ref="validator"/>

    <div class="row mb-3">
        <label for="baseUrlInput" class="form-label bold">Base Url</label>
        <InputText id="baseUrlInput" class="form-control" @bind-Value="_config.BaseUrl"/>
    </div>

    <div class="row mb-3">
        <label for="modelNameInput" class="form-label bold">Model Name</label>
        <InputText id="modelNameInput" class="form-control" @bind-Value="_config.ModelName"/>
    </div>

    <div class="row mb-3">
        <label for="apiKeyInput" class="form-label bold">Api Key</label>
        <InputText id="apiKeyInput" class="form-control" @bind-Value="_config.ApiKey"/>
    </div>

    <h4>Agent input</h4>

    <div class="row mb-3">
        <label for="userRequirements" class="form-label bold">User requirements</label>
        <TextAreaInput id="userRequirements" class="form-control" @bind-Value="_request.UserRequirements"/>
    </div>

    <div class="row mb-3">
        <label for="cvContent" class="form-label bold">Cv content</label>
        <TextAreaInput id="cvContent" class="form-control" @bind-Value="_request.CvContent"/>
    </div>

    <div class="row mb-3">
        <label for="offerContent" class="form-label bold">Offer content</label>
        <TextAreaInput id="offerContent" class="form-control" @bind-Value="_request.OfferContent"/>
    </div>

    <h4>Chat history</h4>
    <div class="chat-container">
        <div class="chat-messages p-3 border rounded mb-3">
            @foreach (var chatItem in chatHistory)
            {
                <div class="message ai-message">
                    <strong>@chatItem.AuthorName</strong>
                    <pre>@chatItem.Content</pre>
                </div>
            }
        </div>
    </div>

    <ValidationSummary/>

    <div class="mt-3">
        <h4>Status:</h4>
        @if (isWorking)
        {
            <div class="spinner-border" role="status">
                <span class="sr-only"></span>
            </div>
            <h5>Do not leave this page. Ai offer summary is in progress...</h5>
        }
        else
        {
            <h5>Ready to summarize offers</h5>
        }
    </div>

    <div class="row">
        <div class="col-md-6 d-flex flex-column">
            <button class="btn btn-primary mb-3" @onclick="RequestAiSummary" disabled="@isWorking">
                @(isWorking ? "Agent working..." : "Summarize")
            </button>
        </div>
        <div class="col-md-6 d-flex flex-column">
            <button class="btn btn-primary mb-3" @onclick="VerifyModel" disabled="@isWorking">
                @(isWorking ? "Verifying..." : "Verify connection")
            </button>
        </div>
        @* <div class="col-md-6 d-flex flex-column"> *@
        @*     <button class="btn btn-success mb-3" @onclick="SaveConfig" disabled="@isWorking"> *@
        @*         Save config *@
        @*     </button> *@
        @* </div> *@
    </div>
</EditForm>


@code
{
    List<ChatItem> chatHistory = [];
    readonly List<ToastMessage> messages = [];

    private void PushNotification(string message, ToastType toastType = ToastType.Success) =>
        messages.Insert(0, new ToastMessage
        {
            Type = toastType,
            Message = message,
        });

    private bool PreventNavigation => isWorking;

    private async Task OnBeforeInternalNavigation(LocationChangingContext ctx)
    {
        if (!PreventNavigation)
            return;

        var confirm = await _js.InvokeAsync<bool>("confirm", "Are you sure you want to leave this page??");
        if (!confirm)
            ctx.PreventNavigation();
    }
}
