@page "/ai-summary/config"
@using BlazorBootstrap
@using Blazored.FluentValidation

<NavigationLock ConfirmExternalNavigation="@PreventNavigation"
                OnBeforeInternalNavigation="OnBeforeInternalNavigation"/>

<Toasts class="p-3" Messages="messages" Placement="ToastsPlacement.TopRight"/>

<h2>Scraping</h2>

<EditForm Model="_config" disabled="@isWorking">
    <FluentValidationValidator @ref="validator"/>

    <InputText class="form-control" @bind-Value="_config.ApiKey"/>
    <InputText class="form-control" @bind-Value="_config.BaseUrl"/>
    <InputText class="form-control" @bind-Value="_config.ModelName"/>


    <ValidationSummary/>

    <div class="mt-3">
        <h4>Status:</h4>
        @if (isWorking)
        {
            <div class="spinner-border" role="status">
                <span class="sr-only"></span>
            </div>
            <h5>Do not leave this page. Scraping in progress...</h5>
        }
        else
        {
            <h5>Ready to scrape</h5>
        }
    </div>

    <div class="row">
        @* <div class="col-md-6 d-flex flex-column"> *@
        @*     <button class="btn btn-primary mb-3" @onclick="StartAiSummary" disabled="@isWorking"> *@
        @*         @(isWorking ? "Agent working..." : "Summarize") *@
        @*     </button> *@
        @* </div> *@
        <div class="col-md-6 d-flex flex-column">
            <button class="btn btn-primary mb-3" @onclick="VerifyConnection" disabled="@isWorking">
                @(isWorking ? "Verifying..." : "Verify connection")
            </button>
        </div>
        <div class="col-md-6 d-flex flex-column">
            <button class="btn btn-success mb-3" @onclick="SaveConfig" disabled="@isWorking">
                Save config
            </button>
        </div>
    </div>
</EditForm>


@code
{
    readonly List<ToastMessage> messages = [];

    private void PushNotification(string message, ToastType toastType = ToastType.Success) =>
        messages.Insert(0, new ToastMessage
        {
            Type = toastType,
            Message = message,
        });

    private bool PreventNavigation => isWorking;

    private async Task OnBeforeInternalNavigation(LocationChangingContext ctx)
    {
        if (!PreventNavigation)
            return;

        var confirm = await _js.InvokeAsync<bool>("confirm", "Are you sure you want to leave this page??");
        if (!confirm)
            ctx.PreventNavigation();
    }
}
