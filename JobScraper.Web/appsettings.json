{
    "AppSettings": {
        "PageSavingDirectory": "..\\Data\\jobs",
        "TickerQ": {
            "Dashboard": {
                "User": "admin"
            }
        }
    },
    "SecuritySettings": {
        "PersistKeysDirectory": "..\\Data\\keys"
    },
    "ConnectionStrings": {
        "DefaultConnection": "data source=..\\Data\\Jobs.db"
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.File"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft.AspNetCore": "Warning",
                "System.Net.Http.HttpClient": "Warning",
                "Microsoft.EntityFrameworkCore": "Error",
                "Microsoft.SemanticKernel.Agents": "Warning",
                "Microsoft.SemanticKernel.Agents.ChatCompletionAgent": "Warning",
                "JobScraper.Web.Integration.DelegatingHandlers.LoggingDelegatingHandler": "Warning",
                "Wolverine.Runtime.WolverineRuntime": "Warning",
                "Wolverine.Transports.ListeningAgent": "Warning",
                "JasperFx.CodeGeneration.ICodeFile": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "File",
                "Args": {
                    "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
                    "path": "..\\Data\\logs\\logs.log",
                    "rollingInterval": "Day",
                    "fileSizeLimitBytes": 1000000,
                    "retainedFileCountLimit": 30,
                    "restrictedToMinimumLevel": "Warning"
                }
            }
        ]
    },
    "Jwt": {
        "Issuer": "JobScraper",
        "Audience": "JobScraper",
        "SigningKey": "992b56c1d54709eb05743abdb70c16a0"
    },
    "OtelEndpoint": "http://localhost:4317",
    "AllowedHosts": "*"
}
