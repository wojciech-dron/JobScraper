@using JobScraper.Web.Modules.Auth
@using Microsoft.AspNetCore.Components.Authorization
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">JobScraper.Web</a>
    </div>
</div>

<button class="navbar-toggler" @onclick="ToggleNavMenu" title="Navigation menu">
    <span class="navbar-toggler-icon"></span>
</button>

<div class="@($"nav-scrollable flex-column {NavMenuCssClass}")">
    <nav class="nav flex-column flex-grow-1">
        <AuthorizeView>
            <Authorized>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span aria-hidden="true"></span> Job offers
                    </NavLink>
                </div>

                <div class="nav-item px-3 ps-5">
                    <NavLink class="nav-link" href="applications" Match="NavLinkMatch.All">
                        <span aria-hidden="true"></span> Applications
                    </NavLink>
                </div>

                <div class="nav-item px-3 ps-5">
                    <NavLink class="nav-link" href="companies" Match="NavLinkMatch.All">
                        <span aria-hidden="true"></span> Companies
                    </NavLink>
                </div>

                <div class="nav-item px-3 ps-5">
                    <NavLink class="nav-link" href="add-offer" Match="NavLinkMatch.All">
                        <span aria-hidden="true"></span> Add Job Offer
                    </NavLink>
                </div>

                <AuthorizeView Roles="@AppRoles.Admin" Context="customScrapersContext">
                    <div class="nav-item px-3 ps-5">
                        <NavLink class="nav-link" href="custom-scrapers" Match="NavLinkMatch.All">
                            <span aria-hidden="true"></span> Custom Scrapers
                        </NavLink>
                    </div>
                </AuthorizeView>

                <div class="nav-item px-3 ps-5">
                    <NavLink class="nav-link" href="scrape" Match="NavLinkMatch.All">
                        <span aria-hidden="true"></span> Scrape
                    </NavLink>
                </div>

                <AuthorizeView Roles="@AppRoles.AiSummary" Context="aiSummaryContext">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="ai-summary/config" Match="NavLinkMatch.All">
                            <span aria-hidden="true"></span> AI Summary
                        </NavLink>
                    </div>
                </AuthorizeView>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="cv" Match="NavLinkMatch.All">
                        <span aria-hidden="true"></span> CV management
                    </NavLink>
                </div>


                <div class="mt-auto">
                    <AuthorizeView Roles="@AppRoles.Admin" Context="adminContext">
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="users" Match="NavLinkMatch.All">
                                <span aria-hidden="true"></span> Users
                            </NavLink>
                        </div>
                    </AuthorizeView>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="Account/Manage" Match="NavLinkMatch.All">
                            <span aria-hidden="true"></span> @context.User.Identity?.Name
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <form action="Account/Logout" method="post">
                            <AntiforgeryToken/>
                            <input type="hidden" name="ReturnUrl" value="@currentUrl"/>
                            <button type="submit" class="nav-link" Match="NavLinkMatch.All">
                                <span aria-hidden="true"></span> Logout
                            </button>
                        </form>
                    </div>
                </div>


            </Authorized>

            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>

@inject NavigationManager NavigationManager

@code {
    private string? currentUrl;

    // Controls nav menu collapse state
    private bool collapseNavMenu;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : "d-flex";

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose() => NavigationManager.LocationChanged -= OnLocationChanged;
}

