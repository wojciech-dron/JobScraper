@using BlazorMonaco.Editor
@inject IJSRuntime jsRuntime

<StandaloneDiffEditor @ref="_diffEditor" Id="@Id" ConstructionOptions="EditorOptions" CssClass="@CssClass"/>

@code {
    [Parameter] public string Id { get; set; } = "diff-editor";
    [Parameter] public string CssClass { get; set; } = "h-100";
    [Parameter] public string OriginalContent { get; set; } = string.Empty;
    [Parameter] public string ModifiedContent { get; set; } = string.Empty;
    [Parameter] public bool Inline { get; set; }

    private StandaloneDiffEditor? _diffEditor;

    private StandaloneDiffEditorConstructionOptions EditorOptions(StandaloneDiffEditor editor) => new()
    {
        AutomaticLayout = true,
        ScrollBeyondLastColumn = 5,
        FontSize = 12,
        RenderSideBySide = !Inline,
        WordWrap = "on",
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Global.SetTheme(jsRuntime, "vs-dark");
        await InitModels();
    }

    public async Task SetModels(string original, string modified)
    {
        await SetOriginalModel(original);
        await SetModifiedModel(modified);
    }

    public async Task SetOriginalModel(string value)
    {
        OriginalContent = value;
        if (_diffEditor is null)
            return;

        if (_diffEditor.OriginalEditor is null)
        {
            // create task that will set value after InitModels() is executed
            _ = Task.Run(async () =>
            {
                await Task.Delay(300);
                await _diffEditor.OriginalEditor!.SetValue(value);
            });
            return;
        }

        await _diffEditor.OriginalEditor.SetValue(value);
    }

    public async Task SetModifiedModel(string value)
    {
        ModifiedContent = value;
        if (_diffEditor is null)
            return;

        if (_diffEditor.ModifiedEditor is null)
        {
            // create task that will set value after InitModels() is executed
            _ = Task.Run(async () =>
            {
                await Task.Delay(300);
                await _diffEditor.ModifiedEditor!.SetValue(value);
            });
            return;
        }

        await _diffEditor.ModifiedEditor.SetValue(value);
    }

    private async Task InitModels()
    {
        if (_diffEditor is null)
            return;

        var originalModel = await Global.GetModel(jsRuntime, $"{Id}-original") ??
            await Global.CreateModel(jsRuntime, OriginalContent, "markdown", $"{Id}-original");

        var modifiedModel = await Global.GetModel(jsRuntime, $"{Id}-modified") ??
            await Global.CreateModel(jsRuntime, ModifiedContent, "markdown", $"{Id}-modified");

        await _diffEditor.SetModel(new DiffEditorModel
        {
            Original = originalModel,
            Modified = modifiedModel,
        });
    }

    public async Task<string> GetModifiedValueAsync() => _diffEditor is not null
        ? await _diffEditor.ModifiedEditor.GetValue()
        : "";
}
