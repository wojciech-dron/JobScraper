@typeparam TItem

<div class="@(Class ?? "")" style="@(string.IsNullOrEmpty(Style) ? "" : Style)">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label for="@($"{Id}-search")">@Label</label>
    }

    @if (CanFilter)
    {
        <InputText id="@($"{Id}-search")" @bind-Value="SearchPhrase" class="form-control"
                   placeholder="@FilterPlaceholder"/>
    }

    <div class="mt-2">
        @if (!FilteredItems.Any())
        {
            <div class="text-muted">@EmptyText</div>
        }
        else
        {
            @foreach (var item in FilteredItems)
            {
                var isSelected = EqualityComparer<TItem>.Default.Equals(item, SelectedItem);
                <button type="button"
                        class="btn @(isSelected ? "btn-primary" : "btn-outline-primary") btn-sm me-2 mb-2"
                        @onclick="() => SelectItemAsync(item)">
                    @if (item is not null)
                    {
                        @StringSelector(item)
                    }
                </button>
            }
        }
    </div>
</div>

@code {
    private string SearchPhrase { get; set; } = string.Empty;

    private IEnumerable<TItem> FilteredItems => Items
        .Where(item => !CanFilter
            || string.IsNullOrWhiteSpace(SearchPhrase)
            || FilterPredicate(item, SearchPhrase));

    /// <summary>
    ///     The collection of items to display as selectable buttons.
    /// </summary>
    [Parameter]
    public ICollection<TItem> Items { get; set; } = [];

    /// <summary>
    ///     The currently selected item.
    /// </summary>
    [Parameter]
    public TItem? SelectedItem { get; set; }

    /// <summary>
    ///     Event callback invoked when the selected item changes.
    /// </summary>
    [Parameter]
    public EventCallback<TItem?> SelectedItemChanged { get; set; }

    /// <summary>
    ///     Function to convert an item to a display string.
    /// </summary>
    [Parameter]
    public Func<TItem, string> StringSelector { get; set; } = item => item?.ToString() ?? "";

    /// <summary>
    ///     A function that determines whether a given item matches the filter string.
    ///     Default implementation checks if the item's string representation contains the filter string, case-insensitive.
    /// </summary>
    [Parameter]
    public Func<TItem, string, bool> FilterPredicate { get; set; } = (item, filter) => false;

    /// <summary>
    ///     Whether filtering/search is enabled.
    /// </summary>
    [Parameter]
    public bool CanFilter { get; set; }

    /// <summary>
    ///     Optional label displayed above the component.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    ///     Placeholder text for the filter input.
    /// </summary>
    [Parameter]
    public string FilterPlaceholder { get; set; } = "Search...";

    /// <summary>
    ///     Text shown when no items match the filter.
    /// </summary>
    [Parameter]
    public string EmptyText { get; set; } = "No items found";

    /// <summary>
    ///     The id for the component elements.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    ///     Additional CSS classes to apply.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    ///     Additional CSS styles to apply.
    /// </summary>
    [Parameter]
    public string? Style { get; set; }

    private Func<TItem, string, bool> DefaultFilterPredicate =>
        (item, filter) => StringSelector(item).Contains(filter, StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        FilterPredicate ??= DefaultFilterPredicate;
    }

    private async Task SelectItemAsync(TItem item)
    {
        SelectedItem = item;
        await SelectedItemChanged.InvokeAsync(item);
    }
}
